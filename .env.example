# Humsafar Community — Environment Variables
# Copy this file to .env.local and fill in your values

# ── ANALYTICS ──────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── SITE CONFIG ─────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://humsafarcommunity.com
NEXT_PUBLIC_WA_NUMBER=916268496389

# ── SANITY CMS (optional — replace hardcoded data) ─────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_read_token

# ── EMAIL (for newsletter) ──────────────────────────────────────
SENDGRID_API_KEY=your_key
EMAIL_FROM=hello@humsafarcommunity.com

# ── ADMIN ──────────────────────────────────────────────────────
ADMIN_ID=humsafar_admin
ADMIN_PASS=Trek@India2025!
